doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Email Title
    style(type="text/css").
      body {
        font-family: Arial, sans-serif;
        background-color: #f9f9f9;
        margin: 0;
        padding: 0;
      }
      .container {
        max-width: 600px;
        margin: 0 auto;
        padding: 20px;
        background-color: #ffffff;
        border-radius: 8px;
        box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
      }
      .content {
        margin: 20px 0;
      }
      .content a {
        color: #4CAF50;
        text-decoration: underline;
        font-weight: bold;
      }
  body
    .container
      include emailHeader.pug
      .content
        block content
      include emailFooter.pug