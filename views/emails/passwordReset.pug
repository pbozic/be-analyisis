extends ../emailLayout.pug

block content
  p Hello #{name},
  p We received a request to reset your password. Click the link below to reset it:
  p
    a(href=resetLink style="color: #4CAF50; text-decoration: underline;") Reset Password
  p If you did not request a password reset, please ignore this email or contact support if you have questions.
  p Reset Link: #{resetLink}