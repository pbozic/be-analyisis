{
    "name": "klikni-be",
    "version": "0.0.1",
    "private": true,
    "type": "module",
    "scripts": {
        "start": "npx prisma generate && npx prisma migrate deploy &&  nodemon ./server.js",
        "prod": "node ./server.js",
        "dev": "npx prisma generate && npx prisma migrate deploy &&  nodemon ./server.js",
        "server": "nodemon ./server.js",
        "prisma": "npx prisma migrate deploy && npx prisma generate",
        "stripe": "stripe listen --skip-verify --forward-to localhost:3001/api/stripe/webhook",
        "docker:up": "node ./Docker/dev-up.js",
        "docker:down": "docker compose --env-file .env -f ./Docker/docker-compose.yml down",
        "docker:down:full": "docker compose --env-file .env -f ./Docker/docker-compose.yml down --volumes --remove-orphans",
        "docker:build": "node ./Docker/dev-up.js",
        "node:logs": "docker compose --env-file .env -f ./Docker/docker-compose.yml logs -f --tail=50 node-app",
        "node:restart": "docker compose --env-file .env -f ./Docker/docker-compose.yml restart node-app",
        "node:recreate": "docker compose --env-file .env -f ./Docker/docker-compose.yml up -d --force-recreate node-app",
        "node:down": "docker compose --env-file .env -f ./Docker/docker-compose.yml down node-app",
        "seed": "node prisma/seed.js",
        "generate:business": "node lib/generateBusnisses.js",
        "es-tunnel": "ssh -L 19200:localhost:9200 KlikniLive",
        "d": "docker compose --env-file .env -f ./Docker/docker-compose.yml exec node-app",
        "postinstall": "node ./setup-aliases.js && node ./install-wkhtmltopdf.js",
        "alias:setup": "node ./setup-aliases.js",
        "test": "node ./scripts/run-tests.js",
        "test:watch": "npm run test -- --watchAll",
        "lint": "eslint . --ext .js,.ts",
        "lint:quiet": "eslint . --ext .js,.ts --quiet",
        "lint:fix": "eslint . --ext .js,.ts --fix",
        "prepare": "husky",
        "type-check": "tsc --noEmit",
        "docs": "npm run docs:generate && cd docs && npm start",
        "docs:build": "npm run docs:generate && cd docs && npm run build",
        "docs:generate": "node ./scripts/generateDocs.js"
    },
    "lint-staged": {
        "*.{js,ts,jsx,tsx}": [
            "eslint --fix --cache",
            "prettier --write"
        ]
    },
    "prisma": {
        "schema": "./prisma/schema.prisma",
        "seed": "node prisma/seed.js"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.596.0",
        "@aws-sdk/lib-storage": "^3.596.0",
        "@aws-sdk/s3-request-presigner": "^3.596.0",
        "@babel/parser": "^7.27.2",
        "@commitlint/cli": "^19.8.1",
        "@elastic/elasticsearch": "^8.17.0",
        "@googlemaps/google-maps-services-js": "^3.4.0",
        "@googlemaps/routing": "^2.0.1",
        "@joi/date": "^2.1.1",
        "@onesignal/node-onesignal": "^5.0.0-alpha-01",
        "@prisma/client": "^5.14.0",
        "@prisma/sdk": "^4.0.0",
        "@signpdf/signer-p12": "^3.2.4",
        "@signpdf/signpdf": "^3.2.5",
        "@socket.io/redis-adapter": "^8.3.0",
        "@turf/turf": "^7.2.0",
        "arml": "^0.0.12",
        "async_hooks": "^1.0.0",
        "aws-sdk": "^2.1628.0",
        "axios": "^1.7.2",
        "bcrypt": "^6.0.0",
        "canvas": "^2.8.0",
        "chalk": "^4.0.0",
        "comment-parser": "^1.4.1",
        "compression": "^1.8.0",
        "cookie-parser": "~1.4.4",
        "core-js": "^3.37.1",
        "cors": "^2.8.5",
        "crypto": "^1.0.1",
        "date-holidays": "^3.23.12",
        "debug": "^4.3.4",
        "easyqrcodejs-nodejs": "^4.2.6",
        "ejs": "^3.1.6",
        "elastic-apm-node": "^4.11.2",
        "eslint-plugin-prettier": "^5.4.0",
        "express": "~4.16.1",
        "express-fileupload": "^1.2.1",
        "express-form-data": "^2.0.17",
        "fast-glob": "^3.3.3",
        "flatted": "^3.3.3",
        "follow-redirects": "^1.15.9",
        "fontkit": "^2.0.4",
        "googleapis": "^70.0.0",
        "haversine-distance": "^1.2.3",
        "html-pdf": "^3.0.1",
        "http-errors": "~1.6.3",
        "jade": "~1.11.0",
        "joi": "^17.13.1",
        "js-yaml": "^4.1.0",
        "jsonwebtoken": "^9.0.2",
        "jwk-to-pem": "^2.0.7",
        "libphonenumber-js": "^1.11.20",
        "lodash.merge": "^4.6.2",
        "mime-types": "^2.1.35",
        "morgan": "~1.9.1",
        "node-7z": "^3.0.0",
        "node-cron": "^3.0.3",
        "node-forge": "^1.3.1",
        "node-schedule": "^2.0.0",
        "node-signpdf": "^3.0.0",
        "nodemailer": "^6.9.13",
        "nodemon": "^3.1.3",
        "openapi-comment-parser": "^1.0.0",
        "pdf-lib": "^1.17.1",
        "pg": "^8.7.1",
        "pino": "^9.6.0",
        "pino-caller": "^3.4.0",
        "pino-http": "^10.4.0",
        "pino-pretty": "^13.0.0",
        "pug": "^3.0.3",
        "qr-code-styling": "^1.6.0-rc.1",
        "qr-code-styling-node": "^1.5.0",
        "react-export-excel": "^0.5.3",
        "read-excel-file": "^5.2.6",
        "recast": "^0.23.11",
        "redis": "^4.7.0",
        "socket.io": "^4.7.5",
        "stripe": "^15.12.0",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.0",
        "twilio": "^5.1.1",
        "unklogger": "^2.3.0",
        "wkhtmltopdf": "^0.4.0",
        "wkhtmltopdf-installer": "^0.3.2",
        "yaml": "^2.8.0",
        "zod-prisma-types": "~3.1.0"
    },
    "description": "BE server to Klikni project",
    "main": "app.js",
    "author": "Tadej Hiti",
    "license": "ISC",
    "devDependencies": {
        "@faker-js/faker": "^9.5.0",
        "@types/node": "^22.15.20",
        "@typescript-eslint/eslint-plugin": "^8.32.1",
        "@typescript-eslint/parser": "^8.32.1",
        "cross-env": "^7.0.3",
        "dotenv": "^16.5.0",
        "eslint": "^9.27.0",
        "eslint-config-prettier": "^10.1.5",
        "eslint-plugin-import": "^2.31.0",
        "husky": "^9.1.7",
        "jest": "^29.7.0",
        "lint-staged": "^16.0.0",
        "prettier": "^3.5.3",
        "prettier-plugin-prisma": "^5.0.0",
        "prisma": "^5.16.1",
        "prisma-zod-generator": "^0.8.13",
        "supertest": "^7.1.1",
        "ts-node": "^10.9.2",
        "typescript": "^5.8.3",
        "zod": "^3.25.7"
    }
}
