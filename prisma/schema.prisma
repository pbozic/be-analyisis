generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model users {
  first_name      String?
  password        String
  email           String           @unique
  telephone       String           @unique
  profile_picture String?
  created_at      DateTime         @default(now()) @db.Timestamptz(6)
  updated_at      DateTime         @updatedAt @db.Timestamptz(6)
  last_name       String?
  user_id         String           @id @default(uuid()) @db.Uuid
  user_role       USER_ROLES       @default(PERSONAL)
  addresses       user_address[]
  tokens          tokens[]
  phone_verified     Boolean          @default(false)
}

model tokens {
  token_id String   @id @default(uuid()) @db.Uuid
  user_id                String    @db.Uuid
  type                   TokenType @default(API)
  token                  String
  created_at             DateTime @default(now()) @db.Timestamptz(6)
  updated_at             DateTime @updatedAt @db.Timestamptz(6)
  active                 Boolean  @default(true)
  users                  users    @relation(fields: [user_id], references: [user_id])
}

model addresses {
  address_id   String         @id @default(uuid()) @db.Uuid
  address      String
  latitude     String
  longitude    String
  name         String
  icon         String
  street       String
  house_number String
  city         String
  country      String
  postal       String
  users        user_address[]

  @@unique([address, latitude, longitude], name: "uniqueAdressIdentifier")
}

model user_address {
  user_id    String    @db.Uuid
  address_id String    @db.Uuid
  selected   Boolean   @default(false)
  users      users     @relation(fields: [user_id], references: [user_id])
  addresses  addresses @relation(fields: [address_id], references: [address_id])

  @@id([user_id, address_id])
}

model allergens {
  allergen_id String  @id @default(uuid()) @db.Uuid
  name        String
  description String?
  code        Int     @unique @db.SmallInt
}

enum USER_ROLES {
  ADMIN
  PERSONAL
  DRIVER
}

enum TokenType {
  EMAIL
  PHONE_VERIFICATION
  API
  PASSWORD_RESET
}