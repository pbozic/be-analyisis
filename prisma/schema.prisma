generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model finances {
  finance_id          String     @id @default(uuid()) @db.Uuid
  bank_name           String
  account_holder      String
  account_number      String
  payment_preferences Json
  created_at          DateTime   @default(now()) @db.Timestamptz(6)
  updated_at          DateTime   @default(now()) @updatedAt @db.Timestamptz(6)
  business            business[]

  @@unique([account_number], name: "uniqueAccountNumber")
}

model business {
  business_id                     String               @id @unique @default(uuid()) @db.Uuid
  address_id                      String?              @db.Uuid
  delivery_address_id             String?              @db.Uuid
  finance_id                      String?              @db.Uuid
  type                            BUSINESS_TYPE
  is_business_unit                Boolean              @default(false)
  business_group_name             String? // if part of any holding or other business group
  name                            String
  description                     String?
  tax_id                          String
  registration_id                 String
  email                           String               @unique
  telephone                       String?
  telephone_code                  String
  telephone_number                String
  website_url                     String?
  working_hours                   Json?
  seats                           Int?
  minimum_order                   Int
  offers_daily_meals              Boolean              @default(false)
  offers_daily_meals_on_weekend   Boolean              @default(false)
  popular                         Boolean              @default(true)
  new                             Boolean              @default(false)
  created_at                      DateTime             @default(now()) @db.Timestamptz(6)
  updated_at                      DateTime             @default(now()) @updatedAt @db.Timestamptz(6)
  address                         addresses?           @relation(name: "address", fields: [address_id], references: [address_id])
  delivery_address                addresses?           @relation(name: "delivery_address", fields: [delivery_address_id], references: [address_id])
  finances                        finances?            @relation(fields: [finance_id], references: [finance_id])
  business_users                  business_users[]
  documents                       documents[]
  parent_business_id              String?              @db.Uuid
  parent_business                 business?            @relation("parent_business", fields: [parent_business_id], references: [business_id])
  child_businesses                business[]           @relation("parent_business")
  taxi_orders                     taxi_orders[]
  delivery_orders                 delivery_orders[]
  menus                           menus[]
  reviewable_id                   String?              @db.Uuid
  reviewable                      reviewable?          @relation(fields: [reviewable_id], references: [reviewable_id])
  stripe_account_id               String?
  stripe_customer_id              String?
  word_buy_stripe_product_id      String?
  word_buy_stripe_product         local_products?
  word_buy_stripe_subscription_id String?
  word_buys                       word_buy[]
  reservations                    reservations[]
  daily_users_sorted              Json?                @default("[]")
  daily_users_sorting_type        SORTING_TYPE         @default(AUTOMATIC)
  restaurant_overwhelmed          Boolean              @default(false)
  promo_sections                  promo_sections_buy[]
  business_teams                  business_teams[]     @relation("business_to_business_teams")
  business_order_lobbies          order_lobbies[]      @relation("business_to_lobby")
  first_activated_at              DateTime?
  active                          Boolean              @default(false)
  sales_representative_id         String?

  user_favorite_businesses user_favorite_businesses[] @relation("user_favorite_businesses_to_business")
  scoring_points           scoring_points[]           @relation("scoring_points_to_business")

  late_events late_events[] @relation("late_events_to_business")
}

model business_users {
  business_users_id    String       @id @default(uuid()) @db.Uuid
  online               Boolean?     @default(false)
  company_role         COMPANY_ROLE @default(DIRECTOR)
  created_at           DateTime     @default(now()) @db.Timestamptz(6)
  updated_at           DateTime     @default(now()) @updatedAt @db.Timestamptz(6)
  user_id              String       @db.Uuid
  users                users?       @relation(fields: [user_id], references: [user_id])
  business_id          String       @db.Uuid
  business             business?    @relation(fields: [business_id], references: [business_id])
  operating_address_id String?      @db.Uuid
  operating_address    addresses?   @relation("business_users_operating_address", fields: [operating_address_id], references: [address_id])
}

model users {
  user_id                                String               @id @unique @default(uuid()) @db.Uuid
  first_name                             String?
  last_name                              String?
  password                               String
  gender                                 GENDER?
  email                                  String?
  telephone                              String               @unique
  telephone_code                         String
  telephone_number                       String
  date_of_birth                          DateTime             @db.Date
  created_at                             DateTime             @default(now()) @db.Timestamptz(6)
  updated_at                             DateTime             @default(now()) @updatedAt @db.Timestamptz(6)
  user_role                              USER_ROLES           @default(PERSONAL)
  second_role                            USER_ROLES?
  addresses                              user_address[]
  tokens                                 tokens[]
  phone_verified                         Boolean              @default(false)
  notification_preferences               Json?
  taxi_preferences                       Json?
  business_users                         business_users[]
  driver                                 drivers?
  orders                                 taxi_orders[]
  documents                              documents[]
  delivery_driver                        delivery_drivers?
  delivery_orders                        delivery_orders[]
  reviewable_id                          String?              @db.Uuid
  reviewable                             reviewable?          @relation(fields: [reviewable_id], references: [reviewable_id])
  reviews                                reviews[]            @relation("review_author")
  review_complete                        Boolean              @default(true)
  one_signal_id                          String?
  stripe_customer_id                     String?
  wallet_balance                         Float                @default(0)
  transactions                           transactions[]
  reservations                           reservations[]
  transfer_preferences                   Json?
  allergies_preferences                  Json?
  spicy_preferences                      Json?
  radio_preferences                      Json?
  subscribed_to_daily_meals              Boolean              @default(false)
  daily_meal_preferences                 Json?
  details                                Json?
  flag_changes                           flag_history[]
  taxi_push_notification_preferences     Json?
  transfer_push_notification_preferences Json?
  delivery_push_notification_preferences Json?
  spoken_languages                       Json?
  lost_items                             lost_items[]
  daily_meal_day_preferences             Json?                @default("[]")
  disabled                               Boolean              @default(false)
  active                                 Boolean              @default(true)
  child_users                            group_users[]        @relation("parent_user")
  parent_user                            group_users?         @relation("child_user")
  language                               String?              @default("en")
  wallet_funds                           wallet_funds[]       @relation("wallet_funds")
  apple_id                               String?
  google_id                              String?
  referral_code                          String?              @unique @default(dbgenerated("upper(\"substring\"(md5((random())::text), 1, 6))")) @db.Char(6)
  referrals_made                         referrals[]          @relation("referrer")
  referral                               referrals?           @relation("referred")
  //credits                                credits[]
  cashback                               cashback[]
  activated_at                           DateTime?
  business_teams_id                      String?              @db.Uuid
  business_teams                         business_teams?      @relation("user_to_business_team", fields: [business_teams_id], references: [business_teams_id])
  order_lobby_users                      order_lobby_users[]  @relation("user_to_OL_user")
  promo_section_buys                     promo_sections_buy[]
  allow_marketing_push_notifications     Boolean?             @default(false)
  allow_ads_personalization              Boolean?             @default(false)
  allow_newsletter                       Boolean?             @default(false)

  user_favorite_businesses user_favorite_businesses[] @relation("user_favorite_businesses_to_user")
  scoring_points           scoring_points[]           @relation("scoring_points_to_user")

  late_events late_events[] @relation("late_events_to_user")
}

model cashback {
  cashback_id       String           @id @unique @default(uuid()) @db.Uuid
  user_id           String           @db.Uuid
  amount            Float
  type              CASHBACK_TYPE
  source            CASHBACK_SOURCE
  status            CASHBACK_STATUS  @default(PENDING)
  description       String?
  earned_at         DateTime         @default(now()) @db.Timestamptz(6)
  expires_at        DateTime?        @db.Timestamptz(6)
  converted_at      DateTime?        @db.Timestamptz(6)
  taxi_order_id     String?          @db.Uuid
  delivery_order_id String?          @db.Uuid
  user              users            @relation(fields: [user_id], references: [user_id])
  taxi_order        taxi_orders?     @relation(fields: [taxi_order_id], references: [order_id])
  delivery_order    delivery_orders? @relation(fields: [delivery_order_id], references: [order_id])

  @@index([user_id, type, status])
  @@index([expires_at])
}

