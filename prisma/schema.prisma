generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model finances {
  finance_id          String     @id @default(uuid()) @db.Uuid
  bank_name           String
  account_holder      String
  account_number      String
  payment_preferences Json
  created_at          DateTime   @default(now()) @db.Timestamptz(6)
  updated_at          DateTime   @default(now()) @updatedAt @db.Timestamptz(6)
  business            business[]

  @@unique([account_number], name: "uniqueAccountNumber")
}

model business {
  business_id              String            @id @unique @default(uuid()) @db.Uuid
  address_id               String?           @db.Uuid
  delivery_address_id      String?           @db.Uuid
  finance_id               String?           @db.Uuid
  type                     BUSINESS_TYPE
  is_business_unit         Boolean           @default(false)
  business_group_name      String? // if part of any holding or other business group
  name                     String
  description              String?
  tax_id                   String
  registration_id          String
  email                    String            @unique
  telephone                String?
  telephone_code           String
  telephone_number         String
  website_url              String?
  working_hours            Json?
  seats                    Int?
  minimum_order            Int
  offers_daily_meals       Boolean           @default(false)
  popular                  Boolean           @default(true)
  new                      Boolean           @default(false)
  created_at               DateTime          @default(now()) @db.Timestamptz(6)
  updated_at               DateTime          @default(now()) @updatedAt @db.Timestamptz(6)
  address                  addresses?        @relation(name: "address", fields: [address_id], references: [address_id])
  delivery_address         addresses?        @relation(name: "delivery_address", fields: [delivery_address_id], references: [address_id])
  finances                 finances?         @relation(fields: [finance_id], references: [finance_id])
  business_users           business_users[]
  documents                documents[]
  parent_business_id       String?           @db.Uuid
  parent_business          business?         @relation("parent_business", fields: [parent_business_id], references: [business_id])
  child_businesses         business[]        @relation("parent_business")
  taxi_orders              taxi_orders[]
  delivery_orders          delivery_orders[]
  menus                    menus[]
  reviewable_id            String?           @db.Uuid
  reviewable               reviewable?       @relation(fields: [reviewable_id], references: [reviewable_id])
  stripe_account_id        String?
  reservations             reservations[]
  daily_users_sorted       Json?             @default("[]")
  daily_users_sorting_type SORTING_TYPE      @default(AUTOMATIC)
}

model business_users {
  business_users_id    String       @id @default(uuid()) @db.Uuid
  online               Boolean?     @default(false)
  company_role         COMPANY_ROLE @default(DIRECTOR)
  created_at           DateTime     @default(now()) @db.Timestamptz(6)
  updated_at           DateTime     @default(now()) @updatedAt @db.Timestamptz(6)
  user_id              String       @db.Uuid
  users                users?       @relation(fields: [user_id], references: [user_id])
  business_id          String       @db.Uuid
  business             business?    @relation(fields: [business_id], references: [business_id])
  operating_address_id String?      @db.Uuid
  operating_address    addresses?   @relation("business_users_operating_address", fields: [operating_address_id], references: [address_id])
}

model users {
  user_id                       String            @id @unique @default(uuid()) @db.Uuid
  first_name                    String?
  last_name                     String?
  password                      String
  gender                        GENDER?
  email                         String?
  telephone                     String?           @unique
  telephone_code                String?
  telephone_number              String?
  date_of_birth                 DateTime          @db.Date
  created_at                    DateTime          @default(now()) @db.Timestamptz(6)
  updated_at                    DateTime          @default(now()) @updatedAt @db.Timestamptz(6)
  user_role                     USER_ROLES        @default(PERSONAL)
  addresses                     user_address[]
  tokens                        tokens[]
  phone_verified                Boolean           @default(false)
  push_notification_preferences Json?
  notification_preferences      Json?
  taxi_preferences              Json?
  business_users                business_users[]
  driver                        drivers?
  orders                        taxi_orders[]
  documents                     documents[]
  delivery_driver               delivery_drivers?
  delivery_orders               delivery_orders[]
  reviewable_id                 String?           @db.Uuid
  reviewable                    reviewable?       @relation(fields: [reviewable_id], references: [reviewable_id])
  reviews                       reviews[]         @relation("review_author")
  review_complete               Boolean           @default(true)
  one_signal_id                 String?
  stripe_customer_id            String?
  wallet_balance                Float             @default(0)
  transactions                  transactions[]
  reservations                  reservations[]
  transfer_preferences          Json?
  allergies_preferences         Json?
  spicy_preferences             Json?
  radio_preferences             Json?
  subscribed_to_daily_meals     Boolean           @default(false)
  daily_meal_preferences        Json?
  details                       Json?
}

model documents {
  document_id        String            @id @default(uuid()) @db.Uuid
  document_type      DOCUMENT_TYPE
  created_at         DateTime          @default(now()) @db.Timestamptz(6)
  updated_at         DateTime          @default(now()) @updatedAt @db.Timestamptz(6)
  expiration_date    DateTime?         @db.Timestamptz(6)
  issue_date         DateTime?         @db.Timestamptz(6)
  additional_info    Json? // JSON field for any additional document-specific information
  files              files[]
  driver_id          String?           @db.Uuid
  drivers            drivers?          @relation(fields: [driver_id], references: [driver_id])
  delivery_driver_id String?           @db.Uuid
  delivery_driver    delivery_drivers? @relation(fields: [delivery_driver_id], references: [delivery_driver_id])
  business_id        String?           @db.Uuid
  business           business?         @relation(fields: [business_id], references: [business_id])
  user_id            String?           @db.Uuid
  user               users?            @relation(fields: [user_id], references: [user_id])
  vehicle_id         String?           @db.Uuid
  vehicles           vehicles?         @relation(fields: [vehicle_id], references: [vehicle_id])
  menu_item_id       String?           @db.Uuid
  menu_items         menu_items?       @relation(fields: [menu_item_id], references: [menu_item_id])
  lost_item_id       String?           @db.Uuid
  lost_items         lost_items?       @relation(fields: [lost_item_id], references: [lost_item_id])
}

model files {
  file_id     String     @id @default(uuid()) @db.Uuid
  url         String
  file_type   FILE_TYPE
  mime_type   String
  created_at  DateTime   @default(now()) @db.Timestamptz(6)
  updated_at  DateTime   @default(now()) @updatedAt @db.Timestamptz(6)
  document_id String?    @db.Uuid
  documents   documents? @relation(fields: [document_id], references: [document_id])
}

model tokens {
  token_id   String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  type       TokenType @default(API)
  token      String    @unique
  expires_at DateTime  @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  active     Boolean   @default(true)
  users      users     @relation(fields: [user_id], references: [user_id])
}

model addresses {
  address_id                  String           @id @default(uuid()) @db.Uuid
  address                     String
  latitude                    String
  longitude                   String
  street                      String?
  house_number                String?
  city                        String?
  country                     String?
  postal                      String?
  users                       user_address[]
  businesses                  business[]       @relation(name: "address")
  businesses_delivery_address business[]       @relation(name: "delivery_address")
  business_users              business_users[] @relation("business_users_operating_address")

  @@unique([address, latitude, longitude], name: "uniqueAddressIdentifier")
}

model user_address {
  user_id    String    @db.Uuid
  address_id String    @db.Uuid
  name       String?
  icon       String?
  primary    Boolean   @default(false)
  users      users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  address    addresses @relation(fields: [address_id], references: [address_id], onDelete: Cascade)

  @@id([user_id, address_id])
}

model delivery_drivers {
  delivery_driver_id    String                @id @default(uuid()) @db.Uuid
  online                Boolean?              @default(false)
  on_order              Boolean?              @default(false)
  delivers_daily_meals  Boolean?              @default(false)
  working_hours         Json?
  business_id           String?               @db.Uuid
  created_at            DateTime              @default(now()) @db.Timestamptz(6)
  updated_at            DateTime              @default(now()) @updatedAt @db.Timestamptz(6)
  user_id               String?               @unique @db.Uuid
  user                  users?                @relation(fields: [user_id], references: [user_id])
  vehicles              vehicles[]
  orders                delivery_orders[]
  received_orders       delivery_order_sent[]
  documents             documents[]
  location              Json?
  delivery_timeline     Json?                 @default("[]")
  last_ping_at          DateTime              @default(now()) @db.Timestamptz(6)
  on_daily_meals        Boolean?              @default(false)
  is_inactive           Boolean?              @default(false)
  scheduled_meals_route Json?                 @default("[]")
}

model drivers {
  driver_id         String            @id @default(uuid()) @db.Uuid
  business_id       String?           @db.Uuid
  online            Boolean?          @default(false)
  on_order          Boolean?          @default(false)
  working_hours     Json?
  ride_requirements Json?
  created_at        DateTime          @default(now()) @db.Timestamptz(6)
  updated_at        DateTime          @default(now()) @updatedAt @db.Timestamptz(6)
  user_id           String?           @unique @db.Uuid
  user              users?            @relation(fields: [user_id], references: [user_id])
  vehicles          vehicles[]
  orders            taxi_orders[]
  received_orders   taxi_order_sent[]
  documents         documents[]
  location          Json?
  last_ping_at      DateTime          @default(now()) @db.Timestamptz(6)
  is_inactive       Boolean?          @default(false)
}

model vehicles {
  vehicle_id               String                  @id @unique @default(uuid()) @db.Uuid
  business_id              String?                 @db.Uuid
  active                   Boolean?                @default(true)
  class                    VEHICLE_CLASS?
  category                 VEHICLE_CATEGORY?
  make                     String?
  model                    String?
  color                    String?
  license_plate            String?
  created_at               DateTime                @default(now()) @db.Timestamptz(6)
  updated_at               DateTime                @default(now()) @updatedAt @db.Timestamptz(6)
  driver_id                String?                 @db.Uuid
  driver                   drivers?                @relation(fields: [driver_id], references: [driver_id])
  documents                documents[]
  delivery_driver_id       String?                 @db.Uuid
  delivery_driver          delivery_drivers?       @relation(fields: [delivery_driver_id], references: [delivery_driver_id])
  vehicle_specification_id String?                 @unique @db.Uuid
  vehicle_specification    vehicle_specifications? @relation(fields: [vehicle_specification_id], references: [vehicle_specification_id])
}

model vehicle_specifications {
  vehicle_specification_id String           @id @unique @default(uuid()) @db.Uuid
  class                    VEHICLE_CLASS
  category                 VEHICLE_CATEGORY
  people                   String
  start_cost               String
  per_kilometre            String
  per_minute               String
  vehicle_id               String?          @db.Uuid
  vehicle                  vehicles?
}

model reviewable {
  reviewable_id String     @id @default(uuid()) @db.Uuid
  reviews       reviews[]
  user          users[]
  business      business[]
}

model reviews {
  review_id     String     @id @default(uuid()) @db.Uuid
  reviewable_id String     @db.Uuid
  author_id     String     @db.Uuid
  rating        Float?
  comment       String?
  feedback      Json?
  created_at    DateTime   @default(now()) @db.Timestamptz(6)
  updated_at    DateTime   @default(now()) @updatedAt @db.Timestamptz(6)
  reviewable    reviewable @relation(fields: [reviewable_id], references: [reviewable_id])
  author        users      @relation(fields: [author_id], references: [user_id], name: "review_author")
}

model allergens {
  allergen_id String  @id @default(uuid()) @db.Uuid
  name        String
  description String?
  code        Int     @unique @db.SmallInt
}

model taxi_orders {
  order_id              String            @id @default(uuid()) @db.Uuid
  user_id               String            @db.Uuid
  driver_id             String?           @db.Uuid
  route                 Json
  pickup_location       Json
  delivery_location     Json?
  payment               Json?
  estimates             Json?
  timeline              Json              @default("[]")
  preferences           Json?
  status                TAXI_ORDER_STATUS
  last_sent_at          DateTime?         @db.Timestamptz(6)
  created_at            DateTime          @default(now()) @db.Timestamptz(6)
  updated_at            DateTime          @default(now()) @updatedAt @db.Timestamptz(6)
  business_id           String?           @db.Uuid
  business              business?         @relation(fields: [business_id], references: [business_id])
  driver                drivers?          @relation(fields: [driver_id], references: [driver_id])
  user                  users?            @relation(fields: [user_id], references: [user_id])
  history               taxi_order_sent[]
  telephone             String?
  cancellation_reason   String?
  find_drivers_attempts Int?              @default(0)
  is_scheduled          Boolean           @default(false)
  parent_order_id       String?           @db.Uuid
  parent_order          taxi_orders?      @relation("grouped_orders", fields: [parent_order_id], references: [order_id])
  grouped_orders        taxi_orders[]     @relation("grouped_orders")
  type                  ORDER_TYPE        @default(TAXI)
}

model taxi_order_sent {
  taxi_order_sent_id String       @id @default(uuid()) @db.Uuid
  order_id           String       @db.Uuid
  driver_id          String       @db.Uuid
  accepted           Boolean      @default(false)
  location           Json?
  timeline           Json         @default("[]")
  created_at         DateTime     @default(now()) @db.Timestamptz(6)
  updated_at         DateTime     @default(now()) @updatedAt @db.Timestamptz(6)
  order              taxi_orders? @relation(fields: [order_id], references: [order_id], onDelete: Cascade)
  driver             drivers?     @relation(fields: [driver_id], references: [driver_id])

  @@unique([order_id, driver_id], name: "taxi_order_sent_driver_unique")
}

model delivery_orders {
  order_id              String                @id @default(uuid()) @db.Uuid
  user_id               String?               @db.Uuid
  route                 Json
  pickup_location       Json
  delivery_location     Json
  payment               Json?
  estimates             Json?
  items                 Json
  details               Json?
  courier_instructions  Json?
  restaurant_message    Json?
  scheduled             Json?
  timeline              Json                  @default("[]")
  status                DELIVERY_ORDER_STATUS
  last_sent_at          DateTime?             @db.Timestamptz(6)
  created_at            DateTime              @default(now()) @db.Timestamptz(6)
  updated_at            DateTime              @default(now()) @updatedAt @db.Timestamptz(6)
  user                  users?                @relation(fields: [user_id], references: [user_id])
  history               delivery_order_sent[]
  delivery_driver_id    String?               @db.Uuid
  delivery_driver       delivery_drivers?     @relation(fields: [delivery_driver_id], references: [delivery_driver_id])
  business_id           String?               @db.Uuid
  business              business?             @relation(fields: [business_id], references: [business_id])
  payment_intent_id     String?
  transactions          transactions[]
  find_drivers_attempts Int?                  @default(0)
  is_daily_meal         Boolean               @default(false)
}

model delivery_order_sent {
  delivery_order_sent_id String            @id @default(uuid()) @db.Uuid
  order_id               String            @db.Uuid
  accepted               Boolean           @default(false)
  location               Json
  timeline               Json              @default("[]")
  created_at             DateTime          @default(now()) @db.Timestamptz(6)
  updated_at             DateTime          @default(now()) @updatedAt @db.Timestamptz(6)
  order                  delivery_orders?  @relation(fields: [order_id], references: [order_id])
  delivery_driver_id     String            @db.Uuid
  delivery_driver        delivery_drivers? @relation(fields: [delivery_driver_id], references: [delivery_driver_id])

  @@unique([order_id, delivery_driver_id], name: "delivery_order_sent_driver_unique")
}

model menus {
  menu_id                 String            @id @default(uuid()) @db.Uuid
  business_id             String            @db.Uuid
  active                  Boolean           @default(true)
  business                business          @relation(fields: [business_id], references: [business_id])
  categories              menu_categories[]
  menu_categories_ordered Json? // JSON field to store ordered category IDs

  @@unique([menu_id])
}

model menu_categories {
  menu_category_id   String       @id @default(uuid()) @db.Uuid
  names              Json // l10n names
  description        Json // l10n descriptions
  categories         String[]
  business_id        String       @db.Uuid
  menu_items         menu_items[] @relation("menu_items_in_category")
  menu_id            String?      @db.Uuid
  menu               menus?       @relation(fields: [menu_id], references: [menu_id])
  menu_items_ordered Json? // JSON field to store ordered menu item IDs

  @@unique([menu_category_id])
}

model menu_items {
  menu_item_id     String           @id @default(uuid()) @db.Uuid
  names            Json // l10n names
  image            String?
  description      Json // l10n descriptions
  allergens        String[]
  spicy_level      Int
  unit_size        String
  price            Float
  discount         Float?
  sides            String[] // Optional, for sides
  extras           String[] // Optional, for extras, inside are menu_ids
  ingredients      Json // Includes allergen and multilingual names
  availability     String[] // Array of availability -> ["MON", "TUE", "WED", "THU", "FRI", "SAT", "SUN"]
  business_id      String           @db.Uuid
  menu_category_id String?          @db.Uuid
  menu_category    menu_categories? @relation("menu_items_in_category", fields: [menu_category_id], references: [menu_category_id])
  documents        documents[]

  @@unique([menu_item_id])
}

model transactions {
  id                String           @id @default(uuid())
  user_id           String           @db.Uuid
  amount            Float
  type              TRANSACTION_TYPE // Enum for 'credit' or 'debit'
  description       String?
  createdAt         DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime         @default(now()) @updatedAt @db.Timestamptz(6)
  delivery_order_id String?          @db.Uuid
  order             delivery_orders? @relation(fields: [delivery_order_id], references: [order_id])
  user              users            @relation(fields: [user_id], references: [user_id])
}

enum TRANSACTION_TYPE {
  DEBIT
  CREDIT
}

model reservations {
  reservation_id String             @id @default(uuid()) @db.Uuid
  seats          Int
  date           DateTime           @db.Timestamptz(6)
  time           String
  created_at     DateTime           @default(now()) @db.Timestamptz(6)
  updated_at     DateTime           @default(now()) @updatedAt @db.Timestamptz(6)
  business_id    String             @db.Uuid
  business       business           @relation(fields: [business_id], references: [business_id])
  user_id        String             @db.Uuid
  user           users              @relation(fields: [user_id], references: [user_id])
  status         RESERVATION_STATUS @default(PENDING)
  table          Int?
}

model lost_items {
  lost_item_id String      @id @default(uuid()) @db.Uuid
  description  String
  documents    documents[]
  found        Boolean?    @default(false)
  created_at   DateTime    @default(now()) @db.Timestamptz(6)
}

enum USER_ROLES {
  ADMIN
  BUSINESS_OWNER
  BUSINESS_MANAGER
  BUSINESS_CARETAKER
  BUSINESS_USER
  PERSONAL
  DRIVER
  DELIVERY_DRIVER
  DISPATCHER
}

enum TokenType {
  EMAIL
  PHONE_VERIFICATION
  API
  PASSWORD_RESET
}

enum BUSINESS_TYPE {
  TRANSFER
  MERCHANT
}

enum MERCHANT_TYPE {
  RESTAURANT
  BAR
  MARKET
  STORE
}

enum BUSINESS_CATEGORY {
  TAXI
  TRANSFER
  MERCHANT
}

enum FILE_TYPE {
  IMAGE
  DOCUMENT
}

enum DOCUMENT_TYPE {
  // USER
  NATIONAL_ID
  PASSPORT
  PROFILE_PICTURE
  // PARTNER / DRIVER
  LOGO
  BANNER
  DRIVING_LICENSE
  TAXI_LICENCE
  PASSENGER_TRANSFER_LICENSE
  BACKGROUND_CHECK_REPORT
  // VEHICLE
  VEHICLE_REGISTRATION
  VEHICLE_INSURANCE
  VEHICLE_TECHNICAL_INSPECTION

  // MERCHANT
  OPERATING_PERMIT
  HACCP_CERTIFICATION
  BUSINESS_LICENSE

  // MENU_ITEM
  MENU_ITEM_IMAGE

  // LOST_ITEM
  LOST_ITEM

  HEALTH_DECLARATION
}

enum TAXI_ORDER_STATUS {
  PENDING
  TAXI_ACCEPTED
  TAXI_REJECTED
  TAXI_CANCELED
  TAXI_WAITING
  TAXI_DRIVING
  TAXI_ARRIVED
  TAXI_COMPLETED
  CUSTOMER_CANCELED

  TRANSFER_ACCEPTED
  TRANSFER_COMPLETED
}

enum DELIVERY_ORDER_STATUS {
  // DELIVERY
  PENDING
  DELIVERY_ACCEPTED
  DELIVERY_REJECTED
  DELIVERY_CANCELED
  DELIVERY_PICKED_UP
  DELIVERY_IN_DELIVERY
  DELIVERY_DELAYED
  DELIVERY_ARRIVED
  DELIVERY_DELIVERED
  DELIVERY_COMPLETED
  CUSTOMER_CANCELED
  CUSTOMER_PAYMENT_FAILED
  CUSTOMER_PAYMENT_SUCCESSFUL
  CUSTOMER_PAYMENT_PENDING

  // MERCHANT
  MERCHANT_ACCEPTED
  MERCHANT_REJECTED
  MERCHANT_CANCELED
  MERCHANT_PREPARING
  MERCHANT_DELAYED
  MERCHANT_READY_FOR_PICKUP
  MERCHANT_REFUNDED
  MERCHANT_HIGH_DEMAND
}

enum VEHICLE_CATEGORY {
  STANDARD
  PREMIUM
}

enum VEHICLE_CLASS {
  SEDAN
  CARAVAN
  SUV
  MINIVAN
  VAN
  MINIBUS
  BUS
  CARGO_VAN
}

enum GENDER {
  MALE
  FEMALE
  OTHER
}

enum COMPANY_ROLE {
  DIRECTOR
  MANAGER
  REPRESENTATIVE_OF_SALES
  HEAD_OF_PROCUREMENT
}

enum RESERVATION_STATUS {
  PENDING
  TABLE_RESERVATION_ACCEPTED
  TABLE_RESERVATION_REJECTED
  TABLE_RESERVATION_CANCELED
  TABLE_RESERVATION_COMPLETED
  TABLE_RESERVATION_EXPIRED
}

enum ORDER_TYPE {
  TAXI
  TRANSFER_PRIVATE
  TRANSFER_SHUTTLE
}

enum SORTING_TYPE {
  AUTOMATIC
  MANUAL
}
