enum PERMISSION_SCOPE {
  GLOBAL
  BUSINESS
  USER
}

model users {
  user_id                                String               @id @unique @default(uuid()) @db.Uuid
  first_name                             String?
  last_name                              String?
  password                               String
  gender                                 GENDER?
  email                                  String?
  telephone                              String               @unique
  telephone_code                         String
  telephone_number                       String
  date_of_birth                          DateTime             @db.Date
  created_at                             DateTime             @default(now()) @db.Timestamptz(6)
  updated_at                             DateTime             @default(now()) @updatedAt @db.Timestamptz(6)
  user_role                              USER_ROLES           @default(PERSONAL)
  user_roles                             user_roles[]
  addresses                              user_address[]
  tokens                                 tokens[]
  phone_verified                         Boolean              @default(false)
  notification_preferences               Json?
  taxi_preferences                       Json?
  business_users                         business_users[]
  driver                                 drivers?
  orders                                 taxi_orders[]
  documents                              documents[]
  delivery_driver                        delivery_drivers?
  delivery_orders                        delivery_orders[]
  reviewable_id                          String?              @db.Uuid
  reviewable                             reviewable?          @relation(fields: [reviewable_id], references: [reviewable_id])
  reviews                                reviews[]            @relation("review_author")
  review_complete                        Boolean              @default(true)
  one_signal_id                          String?
  stripe_customer_id                     String?
  wallet_balance                         Float                @default(0)
  transactions                           transactions[]
  reservations                           reservations[]
  transfer_preferences                   Json?
  allergies_preferences                  Json?
  spicy_preferences                      Json?
  radio_preferences                      Json?
  subscribed_to_daily_meals              Boolean              @default(false)
  daily_meal_preferences                 Json?
  details                                Json?
  flag_changes                           flag_history[]
  taxi_push_notification_preferences     Json?
  transfer_push_notification_preferences Json?
  delivery_push_notification_preferences Json?
  spoken_languages                       Json?
  lost_items                             lost_items[]
  daily_meal_day_preferences             Json?                @default("[]")
  disabled                               Boolean              @default(false)
  active                                 Boolean              @default(true)
  child_users                            group_users[]        @relation("parent_user")
  parent_user                            group_users?         @relation("child_user")
  language                               String?              @default("en")
  wallet_funds                           wallet_funds[]       @relation("wallet_funds")
  apple_id                               String?
  google_id                              String?
  referral_code                          String?              @unique @default(dbgenerated("upper(\"substring\"(md5((random())::text), 1, 6))")) @db.Char(6)
  referrals_made                         referrals[]          @relation("referrer")
  referral                               referrals?           @relation("referred")
  //credits                                credits[]
  cashback                               cashback[]
  activated_at                           DateTime?
  business_teams_id                      String?              @db.Uuid
  business_teams                         business_teams?      @relation("user_to_business_team", fields: [business_teams_id], references: [business_teams_id])
  order_lobby_users                      order_lobby_users[]  @relation("user_to_OL_user")
  promo_section_buys                     promo_sections_buy[]
  allow_marketing_push_notifications     Boolean?             @default(false)
  allow_ads_personalization              Boolean?             @default(false)
  allow_newsletter                       Boolean?             @default(false)

  user_favorite_businesses user_favorite_businesses[] @relation("user_favorite_businesses_to_user")
  scoring_points           scoring_points[]           @relation("scoring_points_to_user")

  late_events late_events[] @relation("late_events_to_user")

  account_actions         account_actions[] @relation("action_to_affected_user")
  created_account_actions account_actions[] @relation("action_to_creator")
  blog_posts              blog_posts[]

  payments payments[]

  daily_meal_subscriptions daily_meal_subscriptions[]

  user_money_flows user_money_flows[]
  customer customers[]
  booking_history_log booking_history_log[]
  roles user_role[]
  user_permissions user_permission[]
}

model user_roles {
  user_roles_id String     @id @unique @default(uuid()) @db.Uuid
  user_id       String     @db.Uuid
  user          users      @relation(fields: [user_id], references: [user_id])
  role          USER_ROLES @default(PERSONAL)
  primary       Boolean?   @default(false)
}


model role {
  role_id     String   @id @default(uuid()) @db.Uuid
  name        String
  module      MODULE_TYPE
  business_id String?  @db.Uuid // null = global role
  permissions permission[]
  users       user_role[]
  @@unique([name, business_id]) // same role name allowed globally and per business
}

model user_role {
  user_id               String @id @db.Uuid
  role_id               String @db.Uuid
  reservation_module_id String? @db.Uuid

  user                users              @relation(fields: [user_id], references: [user_id])
  role                role               @relation(fields: [role_id], references: [role_id])
  reservation_module reservation_module? @relation(fields: [reservation_module_id], references: [reservation_module_id])
  
  @@unique([user_id, role_id, reservation_module_id])
}

model permission {
  permission_id  String   @id @default(uuid()) @db.Uuid
  role_id        String   @db.Uuid
  action_id      String?  @db.Uuid // null = non-action permission
  name           String?  // for non-action permissions
  description   String?  
  display_name   String?  
  module         MODULE_TYPE
  limit          Int?     // for action usage limits
  scope          PERMISSION_SCOPE @default(GLOBAL)
  group          String?  // for grouping permissions
  role   role    @relation(fields: [role_id], references: [role_id])
  action action? @relation(fields: [action_id], references: [action_id])

  @@unique([role_id, action_id])
  @@unique([role_id, name, module])
}

model user_permission {
  user_permission_id    String   @id @default(uuid()) @db.Uuid
  user_id               String   @db.Uuid
  reservation_module_id String?   @db.Uuid
  action_id             String?  @db.Uuid // optional for non-action permission
  name                  String?  // for non-action override
  display_name          String? 
  module                MODULE_TYPE
  limit                 Int?     // optional limit override
  scope                 PERMISSION_SCOPE @default(GLOBAL)
  is_blocked            Boolean @default(false)
  user                  users              @relation(fields: [user_id], references: [user_id])
  action                action?            @relation(fields: [action_id], references: [action_id])
  reservation_module    reservation_module? @relation(fields: [reservation_module_id], references: [reservation_module_id])

  @@unique([name, module])
  @@unique([action_id, module])
}