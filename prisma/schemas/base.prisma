/// @namespace Referral
/// @summary Referral link between referrer and referred users.
model referrals {
  referral_id      String         @id @default(uuid()) @db.Uuid
  referral_code    String         @db.Char(6)
  referrer_user_id String         @db.Uuid
  referred_user_id String         @unique @db.Uuid
  conditions_met   Boolean        @default(false)
  reward_claimed   Boolean        @default(false)
  created_at       DateTime       @default(now()) @db.Timestamptz(6)
  updated_at       DateTime       @default(now()) @updatedAt @db.Timestamptz(6)
  referrer         users          @relation("referrer", fields: [referrer_user_id], references: [user_id])
  referred         users          @relation("referred", fields: [referred_user_id], references: [user_id])
  credits          wallet_funds[]
}

/// @namespace FamilyUsers
/// @namespace BusinessUsers
/// @summary User allowances for different service wallets and purchase orders.
model allowances {
  allowance_id                   String          @id @default(uuid()) @db.Uuid
  group_user_id                  String?         @unique @db.Uuid
  business_users_id              String?         @unique @db.Uuid
  amount_taxi_wallet             Float           @default(0)
  amount_transfer_wallet         Float           @default(0)
  amount_delivery_wallet         Float           @default(0)
  amount_any_wallet              Float           @default(0)
  amount_taxi_purchase_order     Float?
  amount_transfer_purchase_order Float?
  amount_delivery_purchase_order Float?
  amount_any_purchase_order      Float?
  created_at                     DateTime        @default(now()) @db.Timestamptz(6)
  updated_at                     DateTime        @default(now()) @updatedAt @db.Timestamptz(6)
  user                           group_users?    @relation(fields: [group_user_id], references: [group_user_id], onDelete: Cascade)
  business_user                  business_users? @relation(fields: [business_users_id], references: [business_users_id], onDelete: Cascade)
}

/// @summary Documents attached to business, user, driver, vehicle, menu items or orders.
/// @namespace Documents
/// @erd Files
/// @erd Business
/// @erd Drivers
/// @erd Vehicles
model documents {
  document_id     String        @id @default(uuid()) @db.Uuid
  document_type   DOCUMENT_TYPE
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  updated_at      DateTime      @default(now()) @updatedAt @db.Timestamptz(6)
  expiration_date DateTime?     @db.Timestamptz(6)
  issue_date      DateTime?     @db.Timestamptz(6)
  additional_info Json? // JSON field for any additional document-specific information
  public          Boolean       @default(false)
  files           files[]
  driver_id       String?       @db.Uuid
  drivers         drivers?      @relation(fields: [driver_id], references: [driver_id])
  business_id     String?       @db.Uuid
  business        business?     @relation(fields: [business_id], references: [business_id])
  vehicle_id      String?       @db.Uuid
  vehicles        vehicles?     @relation(fields: [vehicle_id], references: [vehicle_id])
  transaction_id  String?       @db.Uuid
  transactions    transactions? @relation("Documents_transaction", fields: [transaction_id], references: [transaction_id])
  order_id        String?       @db.Uuid
  taxi_order      taxi_orders?  @relation(fields: [order_id], references: [order_id])
}

/// @summary File storage for documents, images, logos, banners, menu items, blog posts, categories, promo banners and more.
/// @namespace Files
/// @erd Documents
/// @erd Business
/// @erd Users
/// @erd MenuItems
/// @erd LostItems
/// @erd PromoAds
model files {
  file_id           String           @id @default(uuid()) @db.Uuid
  url               String?
  file_type         FILE_TYPE
  public            Boolean          @default(false)
  mime_type         String
  created_at        DateTime         @default(now()) @db.Timestamptz(6)
  updated_at        DateTime         @default(now()) @updatedAt @db.Timestamptz(6)
  document_id       String?          @db.Uuid
  documents         documents?       @relation(fields: [document_id], references: [document_id])
  categories        categories[]
  blog_posts        blog_posts[]
  business_logo     business[]       @relation("business_logo")
  business_banner   business[]       @relation("business_banner")
  user_id           String?          @db.Uuid
  user              users?
  menu_items        menu_items[]     @relation("menu_item_image") // TODO: This was needed for duplicate menu_items -> UPDATE DAO
  lost_item_id      String?          @db.Uuid
  lost_item         lost_items?
  promo_banners     promo_banners[]
  delivery_order_id String?          @db.Uuid
  delivery_order    delivery_orders?
}

/// @summary API and session tokens for users.
/// @namespace Users
model tokens {
  token_id   String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  type       TokenType @default(API)
  token      String    @unique
  expires_at DateTime  @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  active     Boolean   @default(true)
  users      users     @relation(fields: [user_id], references: [user_id])
}

/// @summary Postal/geo address used by businesses, users and modules.
/// @namespace Addresses
/// @erd Business
/// @erd Users
/// @erd BusinessUsers
/// @erd DailyMeals
model addresses {
  address_id               String                     @id @default(uuid()) @db.Uuid
  address                  String
  latitude                 String
  longitude                String
  street                   String?
  house_number             String?
  city                     String?
  country                  String?
  postal                   String?
  users                    user_address[]
  businesses               business[]                 @relation(name: "address")
  stores                   stores[]                   @relation(name: "delivery_address")
  food_drinks              food_drinks[]              @relation(name: "delivery_address")
  business_users           business_users[]           @relation("business_users_operating_address")
  daily_meal_subscriptions daily_meal_subscriptions[]
  local_locations          local_locations?
  locations                location[]

  @@unique([address, latitude, longitude], name: "uniqueAddressIdentifier")
}

/// @summary User address book entries linking users to addresses.
/// @namespace Users
/// @erd Addresses
model user_address {
  user_id    String       @db.Uuid
  address_id String       @db.Uuid
  // name       String?
  // icon       String?
  primary    Boolean      @default(false)
  details    Json? // subtype, floor, apartment/door number, entrance, details/courier_instructions
  type       ADDRESS_TYPE @default(HOME)
  users      users        @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  address    addresses    @relation(fields: [address_id], references: [address_id], onDelete: Cascade)

  @@id([user_id, address_id])
}

/// @summary Entity that can be reviewed (business, user, driver, module, store, food/drink).
/// @namespace Users
/// @namespace Drivers
/// @namespace Transport
/// @namespace Stores
/// @namespace FoodDrinks
/// @namespace Reservations
/// @namespace Bookings
/// @hidden
model reviewable {
  reviewable_id       String               @id @default(uuid()) @db.Uuid
  reviews             reviews[]
  // --------------SEPARATOR--------------
  user                users[]
  driver              drivers[]
  reservation_module  reservation_module[]
  reservation_booking booking[]
  transport_module    transport_module[]
  stores              stores[]
  food_drinks         food_drinks[]
}

/// @summary Review record authored by a user about a business or user.
/// @namespace Users
/// @erd Drivers
/// @erd Transport
/// @erd Stores
/// @erd FoodDrinks
/// @erd Reservations
/// @erd Bookings
model reviews {
  review_id     String     @id @default(uuid()) @db.Uuid
  reviewable_id String     @db.Uuid
  author_id     String     @db.Uuid
  rating        Float?
  comment       String?
  feedback      Json?
  created_at    DateTime   @default(now()) @db.Timestamptz(6)
  updated_at    DateTime   @default(now()) @updatedAt @db.Timestamptz(6)
  reviewable    reviewable @relation(fields: [reviewable_id], references: [reviewable_id])
  author        users      @relation(fields: [author_id], references: [user_id], name: "review_author")

  delivery_order delivery_orders? @relation("delivery_order_review")
  taxi_order     taxi_orders?     @relation("taxi_order_review")
  vehicle_id     String?          @db.Uuid
}

/// @namespace Payments
/// @erd Users
/// @erd TaxiOrders
/// @erd DeliveryOrders
/// @erd Documents
/// @erd Wallet
/// @summary Ledger transactions for users and orders (credit/debit entries).
model transactions {
  transaction_id    String           @id @default(uuid()) @db.Uuid
  user_id           String           @db.Uuid
  amount            Float
  type              TRANSACTION_TYPE // Enum for 'credit' or 'debit'
  description       String?
  createdAt         DateTime         @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime         @default(now()) @updatedAt @db.Timestamptz(6)
  delivery_order_id String?          @db.Uuid
  taxi_order_id     String?          @db.Uuid
  wallet_fund_id    String?          @db.Uuid

  taxi_order     taxi_orders?     @relation(fields: [taxi_order_id], references: [order_id])
  delivery_order delivery_orders? @relation(fields: [delivery_order_id], references: [order_id])
  user           users            @relation(fields: [user_id], references: [user_id])
  documents      documents[]      @relation("Documents_transaction")

  wallet_funds wallet_funds? @relation("wallet_funds_transaction", fields: [wallet_fund_id], references: [wallet_funds_id])
}

/// @namespace Payments
/// @erd Users
/// @summary Money flow entries for a user (credits/debits and fees).
model user_money_flows {
  balance_change_id String           @id @default(uuid()) @db.Uuid
  user_id           String           @db.Uuid
  amount            Float
  stripe_fee        Float
  type              TRANSACTION_TYPE
  payment_method    PAYMENT_METHOD?
  created_at        DateTime         @default(now()) @db.Timestamptz(6)
  user              users            @relation(fields: [user_id], references: [user_id])
}

/// @summary Money flow entries for a business (credits/debits and fees).
/// @namespace Payments
/// @erd Business
model business_money_flows {
  balance_change_id String           @id @default(uuid()) @db.Uuid
  business_id       String           @db.Uuid
  amount            Float
  stripe_fee        Float
  type              TRANSACTION_TYPE
  payment_method    PAYMENT_METHOD?
  created_at        DateTime         @default(now()) @db.Timestamptz(6)
  business          business         @relation(fields: [business_id], references: [business_id])
}

/// @namespace Payments
/// @hidden
model payment_intent_logs {
  payment_intent_logs_id String   @id @default(uuid())
  stripe_id              String   @unique
  created_at             DateTime @default(now()) @db.Timestamptz(6)
}

/// @summary Lost and found items reported by users/drivers.
/// @namespace LostItems
/// @erd Users
/// @erd Files
model lost_items {
  lost_item_id String            @id @default(uuid()) @db.Uuid
  user_id      String?           @db.Uuid
  status       LOST_FOUND_STATUS @default(REPORTED)
  description  String
  image_id     String?           @unique @db.Uuid
  image        files?            @relation(fields: [image_id], references: [file_id])
  found        Boolean?          @default(false)
  created_at   DateTime          @default(now()) @db.Timestamptz(6)
  updated_at   DateTime          @default(now()) @updatedAt @db.Timestamptz(6)
  user         users?            @relation(fields: [user_id], references: [user_id], onDelete: SetNull) // Update the relation
}

