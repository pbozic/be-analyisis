/// @namespace Wallet
/// @erd TaxiOrders
/// @erd DeliveryOrders
/// @summary Wallet transfer history for taxi and delivery orders.
model wallet_transfer_history {
  wallet_transfer_history_id String           @id @default(uuid()) @db.Uuid
  order_id                   String           @db.Uuid
  amount                     Float
  created_at                 DateTime         @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime         @default(now()) @updatedAt @db.Timestamptz(6)
  success                    Boolean
  delivery_order             delivery_orders? @relation(fields: [order_id], references: [order_id])
  taxi_order                 taxi_orders?     @relation(fields: [order_id], references: [order_id], map: "wallet_transfer_history_taxi_order_id_fkey")
}

/// @namespace Wallet
/// @erd Users
/// @erd Payments
/// @summary Wallet and credit balances for users with optional expiry and reservations.
model wallet_funds {
  wallet_funds_id                   String         @id @unique @default(uuid()) @db.Uuid
  user_id                           String         @db.Uuid
  referral_id                       String?        @db.Uuid
  charge_id                         String?
  amount                            Int
  reserved_order                    String?        @db.Uuid
  reserved_daily_meals_subscription String?        @db.Uuid
  reserved_business                 String?        @db.Uuid
  created_at                        DateTime       @default(now()) @db.Timestamptz(6)
  updated_at                        DateTime       @default(now()) @updatedAt @db.Timestamptz(6)
  expires_at                        DateTime?      @db.Timestamptz(6)
  type                              FUNDS_TYPE
  status                            CREDIT_STATUS? @default(ACTIVE)
  referral                          referrals?     @relation(fields: [referral_id], references: [referral_id])
  user                              users          @relation("wallet_funds", fields: [user_id], references: [user_id])
  transactions                      transactions[] @relation("wallet_funds_transaction")

  @@unique([user_id, charge_id, reserved_order, reserved_business, type, status, referral_id, expires_at])
}

/// @namespace PromoSections
/// @erd Promo
/// @summary Configurable promotional sections purchasable by businesses.
model promo_sections {
  promo_sections_id      String               @id @default(uuid()) @db.Uuid
  name                   String
  tag                    String
  active                 Boolean              @default(true)
  description            String?
  prices                 Json?
  limits                 Json?
  stripe_product_id      String?
  canPurchase            Boolean
  t1price                Int?
  t2price                Int?
  t3price                Int?
  order                  Int                  @default(autoincrement())
  service_type           PROMO_SERVICE_TYPES
  promo_section_buy      promo_sections_buy[]
  promo_duration_days    Int                  @default(30)
  translatable_id        String               @db.Uuid
  translatable           translatable         @relation(fields: [translatable_id], references: [translatable_id])
  display_cards_per_page Int?                 @default(4)
  promo_analytics        promo_analytics[]
}

/// @namespace PromoAds
/// @erd Files
/// @summary Visual assets attached to promo ads or section buys.
model promo_banners {
  promo_banners_id     String     @id @default(uuid()) @db.Uuid
  type                 String
  size                 String?
  title                String
  text                 String
  promo_section_buy_id String?    @db.Uuid
  file_id              String     @db.Uuid
  files                files      @relation(fields: [file_id], references: [file_id])
  promo_ads_id         String?    @db.Uuid
  promo_ads            promo_ads? @relation(fields: [promo_ads_id], references: [promo_ads_id])
}

/// @summary Purchase of a promo section placement by a business.
/// @namespace PromoSections
/// @erd Business
/// @erd Promo
model promo_sections_buy {
  promo_sections_buy_id String         @id @default(uuid()) @db.Uuid
  promo_sections_id     String         @db.Uuid
  promo_section         promo_sections @relation(fields: [promo_sections_id], references: [promo_sections_id])
  payment_intent_id     String?
  business_id           String         @db.Uuid
  business              business       @relation(fields: [business_id], references: [business_id])
  user_id               String?        @db.Uuid
  bought_by             users?         @relation(fields: [user_id], references: [user_id])
  paid                  Boolean        @default(false)
  active_at             DateTime?
  expires_at            DateTime?
  tier                  Int
  duration              Int            @default(30) // in days
}

/// @namespace PromoAds
/// @erd Promo
/// @summary Promotional advertisements with categories and analytics.
model promo_ads {
  promo_ads_id    String               @id @default(uuid()) @db.Uuid
  title           String
  text            String
  tag             String
  service_type    PROMO_SERVICE_TYPES
  discount        Float                @default(0)
  banner          promo_banners[]
  categories      promo_ads_category[]
  active          Boolean              @default(true)
  code            Int?                 @unique @db.SmallInt
  created_at      DateTime             @default(now()) @db.Timestamptz(6)
  active_at       DateTime?
  active_until    DateTime?
