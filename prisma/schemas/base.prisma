model referrals {
  referral_id      String         @id @default(uuid()) @db.Uuid
  referral_code    String         @db.Char(6)
  referrer_user_id String         @db.Uuid
  referred_user_id String         @unique @db.Uuid
  conditions_met   Boolean        @default(false)
  reward_claimed   Boolean        @default(false)
  created_at       DateTime       @default(now()) @db.Timestamptz(6)
  updated_at       DateTime       @default(now()) @updatedAt @db.Timestamptz(6)
  referrer         users          @relation("referrer", fields: [referrer_user_id], references: [user_id])
  referred         users          @relation("referred", fields: [referred_user_id], references: [user_id])
  credits          wallet_funds[]
}

model group_users {
  group_user_id  String      @id @default(uuid()) @db.Uuid
  parent_user_id String      @db.Uuid
  child_user_id  String      @unique @db.Uuid
  created_at     DateTime    @default(now()) @db.Timestamptz(6)
  updated_at     DateTime    @default(now()) @updatedAt @db.Timestamptz(6)
  parent_user    users       @relation("parent_user", fields: [parent_user_id], references: [user_id])
  child_user     users       @relation("child_user", fields: [child_user_id], references: [user_id])
  allowance      allowances?
  enabled        Boolean     @default(true)
}

model allowances {
  allowance_id                   String          @id @default(uuid()) @db.Uuid
  group_user_id                  String?         @unique @db.Uuid
  business_users_id              String?         @unique @db.Uuid
  amount_taxi_wallet             Float           @default(0)
  amount_transfer_wallet         Float           @default(0)
  amount_delivery_wallet         Float           @default(0)
  amount_any_wallet              Float           @default(0)
  amount_taxi_purchase_order     Float?
  amount_transfer_purchase_order Float?
  amount_delivery_purchase_order Float?
  amount_any_purchase_order      Float?
  created_at                     DateTime        @default(now()) @db.Timestamptz(6)
  updated_at                     DateTime        @default(now()) @updatedAt @db.Timestamptz(6)
  user                           group_users?    @relation(fields: [group_user_id], references: [group_user_id], onDelete: Cascade)
  business_user                  business_users? @relation(fields: [business_users_id], references: [business_users_id], onDelete: Cascade)
}

model documents {
  document_id        String            @id @default(uuid()) @db.Uuid
  document_type      DOCUMENT_TYPE
  created_at         DateTime          @default(now()) @db.Timestamptz(6)
  updated_at         DateTime          @default(now()) @updatedAt @db.Timestamptz(6)
  expiration_date    DateTime?         @db.Timestamptz(6)
  issue_date         DateTime?         @db.Timestamptz(6)
  additional_info    Json? // JSON field for any additional document-specific information
  public             Boolean           @default(false)
  files              files[]
  driver_id          String?           @db.Uuid
  drivers            drivers?          @relation(fields: [driver_id], references: [driver_id])
  delivery_driver_id String?           @db.Uuid
  delivery_driver    delivery_drivers? @relation(fields: [delivery_driver_id], references: [delivery_driver_id])
  business_id        String?           @db.Uuid
  business           business?         @relation(fields: [business_id], references: [business_id])
  user_id            String?           @db.Uuid
  user               users?            @relation(fields: [user_id], references: [user_id])
  vehicle_id         String?           @db.Uuid
  vehicles           vehicles?         @relation(fields: [vehicle_id], references: [vehicle_id])
  menu_item_id       String?           @db.Uuid
  menu_items         menu_items?       @relation(fields: [menu_item_id], references: [menu_item_id])
  lost_item_id       String?           @db.Uuid
  lost_items         lost_items?       @relation(fields: [lost_item_id], references: [lost_item_id])
  transaction_id     String?           @db.Uuid
  transactions       transactions?     @relation("Documents_transaction", fields: [transaction_id], references: [transaction_id])
}

model files {
  file_id     String       @id @default(uuid()) @db.Uuid
  url         String?
  file_type   FILE_TYPE
  public      Boolean      @default(false)
  mime_type   String
  created_at  DateTime     @default(now()) @db.Timestamptz(6)
  updated_at  DateTime     @default(now()) @updatedAt @db.Timestamptz(6)
  document_id String?      @db.Uuid
  documents   documents?   @relation(fields: [document_id], references: [document_id])
  categories  categories[]
  blog_posts  blog_posts[]

  promo_banners promo_banners[]
}

model tokens {
  token_id   String    @id @default(uuid()) @db.Uuid
  user_id    String    @db.Uuid
  type       TokenType @default(API)
  token      String    @unique
  expires_at DateTime  @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  active     Boolean   @default(true)
  users      users     @relation(fields: [user_id], references: [user_id])
}

model addresses {
  address_id                  String                     @id @default(uuid()) @db.Uuid
  address                     String
  latitude                    String
  longitude                   String
  street                      String?
  house_number                String?
  city                        String?
  country                     String?
  postal                      String?
  users                       user_address[]
  businesses                  business[]                 @relation(name: "address")
  businesses_delivery_address business[]                 @relation(name: "delivery_address")
  business_users              business_users[]           @relation("business_users_operating_address")
  daily_meal_subscriptions    daily_meal_subscriptions[]
  local_locations             local_locations?

  @@unique([address, latitude, longitude], name: "uniqueAddressIdentifier")
}

model user_address {
  user_id    String    @db.Uuid
  address_id String    @db.Uuid
  name       String?
  icon       String?
  primary    Boolean   @default(false)
  users      users     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  address    addresses @relation(fields: [address_id], references: [address_id], onDelete: Cascade)

  @@id([user_id, address_id])
}

model driver_activity_settings {
  driver_activity_settings_id String   @id @default(uuid()) @db.Uuid
  first_offline_lockout       Int      @default(30) // Default 30 minutes
  second_offline_lockout      Int      @default(120) // Default 2 hours
  online_timeout              Int      @default(120) // Default 2 hours
  created_at                  DateTime @default(now()) @db.Timestamptz(6)
  updated_at                  DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  active                      Boolean  @default(true)
}

model driver_activity_logs {
  driver_activity_log_id String        @id @default(uuid()) @db.Uuid
  driver_id              String        @db.Uuid
  activity_type          ACTIVITY_TYPE
  started_at             DateTime      @default(now()) @db.Timestamptz(6)
  ended_at               DateTime?     @db.Timestamptz(6)
  timeout_at             DateTime?     @db.Timestamptz(6)
  lockout_until          DateTime?     @db.Timestamptz(6)

  driver drivers @relation(fields: [driver_id], references: [driver_id])

  @@index([driver_id, activity_type])
  @@index([started_at])
  @@index([ended_at])
}

model delivery_drivers {
  delivery_driver_id                String                              @id @default(uuid()) @db.Uuid
  online                            Boolean?                            @default(false)
  on_order                          Boolean?                            @default(false)
  delivers_daily_meals              Boolean?                            @default(false)
  working_hours                     Json?
  business_id                       String?                             @db.Uuid
  created_at                        DateTime                            @default(now()) @db.Timestamptz(6)
  updated_at                        DateTime                            @default(now()) @updatedAt @db.Timestamptz(6)
  user_id                           String?                             @unique @db.Uuid
  user                              users?                              @relation(fields: [user_id], references: [user_id])
  vehicles                          vehicles[]
  orders                            delivery_orders[]
  received_orders                   delivery_order_sent[]
  documents                         documents[]
  location                          Json?
  delivery_timeline                 Json?                               @default("[]")
  last_ping_at                      DateTime                            @default(now()) @db.Timestamptz(6)
  on_daily_meals                    Boolean?                            @default(false)
  is_inactive                       Boolean?                            @default(false)
  scheduled_meals_route             Json?                               @default("[]")
  regions                           String[]
  delivery_driver_history_locations delivery_driver_history_locations[]
  partner_cash_balance              Float?                              @default(0)
  daily_meal_business_id            String?                             @db.Uuid
  daily_meal_business               business?                           @relation(fields: [daily_meal_business_id], references: [business_id])
  subscriptions                     daily_meal_subscriptions[]
}

model drivers {
  driver_id                 String                     @id @default(uuid()) @db.Uuid
  business_id               String?                    @db.Uuid
  online                    Boolean?                   @default(false)
  on_order                  Boolean?                   @default(false)
  working_hours             Json?
  ride_requirements         Json?
  created_at                DateTime                   @default(now()) @db.Timestamptz(6)
  updated_at                DateTime                   @default(now()) @updatedAt @db.Timestamptz(6)
  user_id                   String?                    @unique @db.Uuid
  user                      users?                     @relation(fields: [user_id], references: [user_id])
  vehicles                  vehicle_drivers[]
  current_vehicle_id        String?                    @unique @db.Uuid
  last_used_vehicle_id      String?                    @db.Uuid
  orders                    taxi_orders[]
  received_orders           taxi_order_sent[]
  delivery_orders           delivery_orders[]
  received_delivery_orders  delivery_order_sent[]
  documents                 documents[]
  location                  Json?
  delivery_timeline         Json?                      @default("[]")
  last_ping_at              DateTime                   @default(now()) @db.Timestamptz(6)
  is_inactive               Boolean?                   @default(false)
  transfer_requirements     Json?
  regions                   String[]
  driver_history_locations  driver_history_locations[]
  handles_taxi_orders       Boolean?                   @default(false)
  handles_transfer_orders   Boolean?                   @default(false)
  handles_delivery_orders   Boolean?                   @default(false)
  taxi_orders_toggled       Boolean?                   @default(false)
  transfer_orders_toggled   Boolean?                   @default(false)
  delivery_orders_toggled   Boolean?                   @default(false)
  partner_cash_balance      Float?                     @default(0)
  come_to_work_last_sent_at DateTime?                  @db.Timestamptz(6)
  driver_municipalities     driver_municipalities[]
  current_vehicle           vehicles?                  @relation("driver_current_vehicle", fields: [current_vehicle_id], references: [vehicle_id])
  activity_logs             driver_activity_logs[]
  business                  business?                  @relation(fields: [business_id], references: [business_id])
}

model vehicle_drivers {
  vehicle_drivers_id String   @id @unique @default(uuid()) @db.Uuid
  vehicle_id         String   @db.Uuid
  driver_id          String   @db.Uuid
  can_drive          Boolean  @default(true)
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  updated_at         DateTime @default(now()) @updatedAt @db.Timestamptz(6)
  vehicle            vehicles @relation(fields: [vehicle_id], references: [vehicle_id])
  driver             drivers  @relation(fields: [driver_id], references: [driver_id])

  @@unique([vehicle_id, driver_id])
  @@index([driver_id, can_drive])
  @@index([vehicle_id, can_drive])
}

model vehicles {
  vehicle_id               String                  @id @unique @default(uuid()) @db.Uuid
  business_id              String?                 @db.Uuid
  active                   Boolean?                @default(true)
  class                    VEHICLE_CLASS?
  category                 VEHICLE_CATEGORY?
  make                     String?
  model                    String?
  color                    String?
  license_plate            String?
  created_at               DateTime                @default(now()) @db.Timestamptz(6)
  updated_at               DateTime                @default(now()) @updatedAt @db.Timestamptz(6)
  documents                documents[]
  drivers                  vehicle_drivers[]
  delivery_driver_id       String?                 @db.Uuid
  delivery_driver          delivery_drivers?       @relation(fields: [delivery_driver_id], references: [delivery_driver_id])
  vehicle_specification_id String?                 @unique @db.Uuid
  vehicle_specification    vehicle_specifications? @relation(fields: [vehicle_specification_id], references: [vehicle_specification_id])
  taxi_orders              taxi_orders[]
  delivery_orders          delivery_orders[]
  current_driver           drivers?                @relation("driver_current_vehicle")
}

model vehicle_specifications {
  vehicle_specification_id String           @id @unique @default(uuid()) @db.Uuid
  class                    VEHICLE_CLASS
  category                 VEHICLE_CATEGORY
  people                   String
  start_cost               String
  per_kilometre            String
  per_minute               String
  vehicle_id               String?          @db.Uuid
  vehicle                  vehicles?
}

model reviewable {
  reviewable_id String     @id @default(uuid()) @db.Uuid
  reviews       reviews[]
  user          users[]
  business      business[]
}

model reviews {
  review_id     String     @id @default(uuid()) @db.Uuid
  reviewable_id String     @db.Uuid
  author_id     String     @db.Uuid
  rating        Float?
  comment       String?
  feedback      Json?
  created_at    DateTime   @default(now()) @db.Timestamptz(6)
  updated_at    DateTime   @default(now()) @updatedAt @db.Timestamptz(6)
  reviewable    reviewable @relation(fields: [reviewable_id], references: [reviewable_id])
  author        users      @relation(fields: [author_id], references: [user_id], name: "review_author")
}

model allergens {
  allergen_id String  @id @default(uuid()) @db.Uuid
  name        String
  description String?
  code        Int     @unique @db.SmallInt
}

model taxi_orders {
  order_id                 String                     @id @default(uuid()) @db.Uuid
  user_id                  String                     @db.Uuid
  business_users_id        String?                    @db.Uuid
  business_clients_id      String?                    @db.Uuid
  driver_id                String?                    @db.Uuid
  vehicle_id               String?                    @db.Uuid
  route                    Json
  pickup_location          Json
  delivery_location        Json?
  payment                  Json?
  estimates                Json?
  timeline                 Json                       @default("[]")
  preferences              Json?
  status                   TAXI_ORDER_STATUS
  last_sent_at             DateTime?                  @db.Timestamptz(6)
  created_at               DateTime                   @default(now()) @db.Timestamptz(6)
  updated_at               DateTime                   @default(now()) @updatedAt @db.Timestamptz(6)
  business_id              String?                    @db.Uuid
  business                 business?                  @relation(fields: [business_id], references: [business_id])
  driver                   drivers?                   @relation(fields: [driver_id], references: [driver_id])
  vehicle                  vehicles?                  @relation(fields: [vehicle_id], references: [vehicle_id])
  user                     users?                     @relation(fields: [user_id], references: [user_id])
  business_users           business_users?            @relation(fields: [business_users_id], references: [business_users_id])
  business_clients         business_clients?          @relation(fields: [business_clients_id], references: [business_clients_id])
  history                  taxi_order_sent[]
  telephone                String?
  first_name               String?
  last_name                String?
  cancellation_reason      String?
  find_drivers_attempts    Int?                       @default(0)
  is_scheduled             Boolean                    @default(false)
  parent_order_id          String?                    @db.Uuid
