  menu_category             menu_categories                   @relation(fields: [menu_category_id], references: [menu_category_id])
  daily_meal_category_price daily_meal_category_prices        @relation(fields: [daily_meal_category_price_id], references: [daily_meal_category_prices_id])

  @@unique([subscription_customer_id, intended_date])
  @@index([delivery_date])
  @@index([intended_date])
  @@index([status])
