  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  user                 users                               @relation(fields: [user_id], references: [user_id])
  delivery_driver      delivery_drivers?                   @relation(fields: [delivery_driver_id], references: [delivery_driver_id])
  delivery_address     addresses                           @relation(fields: [delivery_address_id], references: [address_id])
  business             business                            @relation(fields: [business_id], references: [business_id])
  customers            daily_meal_subscription_customers[]
  days                 daily_meal_subscription_days[]
  weekdays             daily_meal_subscription_weekdays[]
  daily_meal_instances daily_meal_instances[]
  payment              payments?                           @relation("PaymentToDMSubscription")
}

model daily_meal_subscription_customers {
  id                           String  @id @default(uuid()) @db.Uuid
  subscription_id              String  @db.Uuid
  daily_meal_category_id       String  @db.Uuid
  daily_meal_category_price_id String  @db.Uuid
  first_name                   String
  last_name                    String
  telephone                    String
  restaurant_comment           String?

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  subscription              daily_meal_subscriptions   @relation(fields: [subscription_id], references: [id], onDelete: Cascade)
  daily_meal_instances      daily_meal_instances[]
  daily_meal_categories     daily_meal_categories?     @relation(fields: [daily_meal_category_id], references: [daily_meal_category_id])
  daily_meal_category_price daily_meal_category_prices @relation(fields: [daily_meal_category_price_id], references: [daily_meal_category_prices_id])
}

model daily_meal_subscription_days {
  id              String   @id @default(uuid()) @db.Uuid
  subscription_id String   @db.Uuid
  intended_date   DateTime @db.Timestamp(0)
  delivery_date   DateTime @db.Timestamp(0)

  subscription daily_meal_subscriptions @relation(fields: [subscription_id], references: [id], onDelete: Cascade)

  @@unique([subscription_id, intended_date])
  @@index([delivery_date])
  @@index([intended_date])
}

model daily_meal_subscription_weekdays {
  id               String @id @default(uuid()) @db.Uuid
  subscription_id  String @db.Uuid
  intended_weekday Int // 0 (Sunday) to 6 (Saturday)
  delivery_weekday Int // 0 (Sunday) to 6 (Saturday)

  subscription daily_meal_subscriptions @relation(fields: [subscription_id], references: [id], onDelete: Cascade)

  @@unique([subscription_id, intended_weekday])
  @@index([intended_weekday])
  @@index([delivery_weekday])
}

model daily_meal_instances {
  id                           String                     @id @default(uuid()) @db.Uuid
  subscription_id              String                     @db.Uuid
  subscription_customer_id     String                     @db.Uuid
  menu_category_id             String                     @db.Uuid
  status                       DAILY_MEAL_INSTANCE_STATUS @default(PLANNED)
  intended_date                DateTime                   @db.Timestamp(0)
  delivery_date                DateTime                   @db.Timestamp(0)
  daily_meal_category_price_id String                     @db.Uuid

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

