/// @summary Business entity representing a merchant/partner account or crm.
/// @namespace Business
/// @erd BusinessUsers
/// @erd CRM
/// @erd Transport
/// @erd Delivery
/// @erd Stores
/// @erd FoodDrinks
/// @erd Reservations
/// @erd Users
/// @erd Addresses
/// @erd Files
///
/// Core company profile linked to address, documents, analytics, roles and users.
model business {
  business_id         String      @id @unique @default(uuid()) @db.Uuid
  address_id          String?     @db.Uuid
  is_business_unit    Boolean     @default(false) // TODO: Remove later
  business_group_name String? // if part of any holding or other business group
  name                String
  description         String?
  tax_id              String
  registration_id     String
  email               String      @unique
  telephone           String
  telephone_code      String // TODO: Remove later
  telephone_number    String // TODO: Remove later
  website_url         String?
  working_hours       Json?
  popular             Boolean     @default(true) // TODO: Remove later
  new                 Boolean     @default(false) // TODO: Remove later
  created_at          DateTime    @default(now()) @db.Timestamptz(6)
  updated_at          DateTime    @default(now()) @updatedAt @db.Timestamptz(6)
  address             addresses?  @relation(name: "address", fields: [address_id], references: [address_id])
  documents           documents[]
  logo_id             String?     @unique @db.Uuid
  logo                files?      @relation("business_logo", fields: [logo_id], references: [file_id])
  banner_id           String?     @unique @db.Uuid
  banner              files?      @relation("business_banner", fields: [banner_id], references: [file_id])
  parent_business_id  String?     @db.Uuid
  parent_business     business?   @relation("parent_business", fields: [parent_business_id], references: [business_id], onDelete: SetNull)
  child_businesses    business[]  @relation("parent_business")

  stripe_account_id               String?
  stripe_customer_id              String?
  word_buy_stripe_subscription_id String?
  word_buys                       word_buy[]
  promo_sections                  promo_sections_buy[]
  analytics                       promo_analytics[]
  first_activated_at              DateTime?
  active                          Boolean              @default(false)
  sales_representative_id         String?

  user_favorite_businesses user_favorite_businesses[] @relation("user_favorite_businesses_to_business")
  scoring_points           scoring_points[]           @relation("scoring_points_to_business")
  account_actions          account_actions[]

  business_money_flows business_money_flows[]
  roles                role[]
  business_users       business_users[]

  types              business_to_types[]
  reservation_module reservation_module?
  transport_module   transport_module?
  stores             stores?
  food_drinks        food_drinks?
  crm_module         crm_module?

  @@index([parent_business_id])
}

/// @summary Junction table linking businesses to their types.
/// @namespace Business
/// @hidden
model business_to_types {
  business_id String   @db.Uuid
  type_id     String   @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  business      business      @relation(fields: [business_id], references: [business_id], onDelete: Cascade)
  business_type business_type @relation(fields: [type_id], references: [type_id], onDelete: Cascade)

  @@id([business_id, type_id])
  @@index([type_id, business_id])
}

/// @summary Types of businesses (e.g., Local, Store, Restaurant).
/// @namespace Business
model business_type {
  type_id    String              @id @default(uuid()) @db.Uuid
  type       String              @unique // TODO: seeder
  created_at DateTime            @default(now()) @db.Timestamptz(6)
  updated_at DateTime            @default(now()) @updatedAt @db.Timestamptz(6)
  businesses business_to_types[]
}

/// @summary User membership within a business (employees/managers).
/// @namespace BusinessUsers
/// @erd Business
/// @erd TaxiOrders
/// @erd DeliveryOrders
/// @erd Bookings
/// @erd Addresses
/// @erd CRM
model business_users {
  business_users_id    String        @id @default(uuid()) @db.Uuid
  online               Boolean?      @default(false) // TODO: remove?
  company_role         COMPANY_ROLE  @default(DIRECTOR)
  created_at           DateTime      @default(now()) @db.Timestamptz(6)
  updated_at           DateTime      @default(now()) @updatedAt @db.Timestamptz(6)
  user_id              String        @db.Uuid
  users                users?        @relation(fields: [user_id], references: [user_id])
  business_id          String        @db.Uuid
  business             business?     @relation(fields: [business_id], references: [business_id])
  operating_address_id String?       @db.Uuid
  operating_address    addresses?    @relation("business_users_operating_address", fields: [operating_address_id], references: [address_id])
  allowance            allowances?
  taxi_orders          taxi_orders[]
  employee             employee?

  @@unique([user_id, business_id], name: "uniqueBusinessUser")
  @@index([business_id])
  @@index([user_id])
}

/// @namespace Cashback
/// @summary Cashback rewards tied to orders or promotions.
model cashback {
  cashback_id       String           @id @unique @default(uuid()) @db.Uuid
  user_id           String           @db.Uuid
  amount            Int
  type              CASHBACK_TYPE
  source            CASHBACK_SOURCE
  status            CASHBACK_STATUS  @default(PENDING)
  description       String?
  earned_at         DateTime         @default(now()) @db.Timestamptz(6)
  expires_at        DateTime?        @db.Timestamptz(6)
  converted_at      DateTime?        @db.Timestamptz(6)
  taxi_order_id     String?          @db.Uuid
  delivery_order_id String?          @db.Uuid
  user              users            @relation(fields: [user_id], references: [user_id])
  taxi_order        taxi_orders?     @relation(fields: [taxi_order_id], references: [order_id])
  delivery_order    delivery_orders? @relation(fields: [delivery_order_id], references: [order_id])

  @@index([user_id, type, status])
  @@index([expires_at])
}

