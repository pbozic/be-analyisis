model payment_transfer_groups {
  payment_transfer_group_id String                @id @default(uuid()) @db.Uuid
  status                    TRANSFER_GROUP_STATUS @default(PENDING)
  type                      TRANSFER_GROUP_TYPE
  amount                    Int
  metadata                  Json?
  payment_id                String                @db.Uuid

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  payment_splits payment_splits[]
  payment        payments         @relation("PaymentToTransferGroups", fields: [payment_id], references: [payment_id], onDelete: Cascade)
}

model daily_meal_categories {
